{
  "taskStatus": {
    "type": "object",
    "properties": {
      "id": {
        "type": "string",
        "description": "Unique identifier for the task"
      },
      "name": {
        "type": "string",
        "description": "Human-readable name of the task"
      },
      "status": {
        "type": "string",
        "enum": ["pending", "running", "completed", "failed"],
        "description": "Current status of the task"
      },
      "progress": {
        "type": "number",
        "minimum": 0,
        "maximum": 100,
        "description": "Progress percentage (0-100)"
      },
      "startTime": {
        "type": "string",
        "format": "date-time",
        "description": "ISO 8601 timestamp when the task started"
      },
      "endTime": {
        "type": "string",
        "format": "date-time",
        "description": "ISO 8601 timestamp when the task ended (null if not completed)"
      },
      "error": {
        "type": "string",
        "description": "Error message if the task failed",
        "nullable": true
      }
    },
    "required": ["id", "name", "status"]
  },
  "taskStatusList": {
    "type": "array",
    "items": {
      "$ref": "#/taskStatus"
    },
    "description": "Array of task status objects"
  },
  "systemStatus": {
    "type": "object",
    "properties": {
      "api": {
        "type": "string",
        "enum": ["connected", "disconnected", "connecting"],
        "description": "API connection status"
      },
      "socket": {
        "type": "string",
        "enum": ["connected", "disconnected", "connecting"],
        "description": "WebSocket connection status"
      },
      "totalTasks": {
        "type": "number",
        "description": "Total number of tasks"
      },
      "runningTasks": {
        "type": "number",
        "description": "Number of currently running tasks"
      },
      "completedTasks": {
        "type": "number",
        "description": "Number of completed tasks"
      },
      "failedTasks": {
        "type": "number",
        "description": "Number of failed tasks"
      }
    },
    "required": [
      "api",
      "socket",
      "totalTasks",
      "runningTasks",
      "completedTasks",
      "failedTasks"
    ]
  }
}
